# =============================================================================
# AgentRun AIO Sandbox 敏感配置示例
# =============================================================================
# 使用前：复制本文件为 .env 并填入真实值；确保 .env 已加入 .gitignore
# 加载方式：在代码入口调用 load_dotenv()
# =============================================================================

# 阿里云访问密钥（创建/删除 Sandbox 等需调用阿里云 API）
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
ALIBABA_CLOUD_REGION=cn-hangzhou

# 账号 ID（SDK 必填，可用阿里云主账号 ID）
# 二选一即可：AGENTRUN_ACCOUNT_ID 或 ALIBABA_CLOUD_ACCOUNT_ID
AGENTRUN_ACCOUNT_ID=your-account-id
# ALIBABA_CLOUD_ACCOUNT_ID=your-account-id

# AIO 模板名称（需先在 AgentRun 控制台创建好 AIO 类型模板）
AIO_TEMPLATE_NAME=your-aio-template

# Sandbox 泛域名（用于多端口域名生成：{port}-{sandbox_id}.{SANDBOX_WILDCARD_DOMAIN}）
SANDBOX_WILDCARD_DOMAIN=sandbox.example.com
